generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  password   String
  verificado Boolean     @default(false)
  rol        Rol         @default(GENERAL)
  favoritos  Favoritos[]
}

enum Rol {
  ADMIN
  GENERAL
  COLABORADOR
  ENTRENADOR
}

model Evento {
  id            Int      @id @default(autoincrement())
  numero_evento Int
  estilo        Estilo
  distancia     Int
  genero        Genero
  edad_min      Int
  edad_max      Int
  estado        Estado   @default(PENDIENTE)
  series        Serie[]
}

enum Estilo {
  CROL
  MARIPOSA
  PECHO
  ESPALDA
}

enum Genero {
  MASCULINO
  FEMENINO
  MIXTO
}

enum Estado {
  PENDIENTE
  EN_CURSO
  FINALIZADO
}

model Serie {
  id                   Int       @id @default(autoincrement())
  numero_serie         Int
  hora_inicio_estimada DateTime?
  evento_id            Int
  evento               Evento    @relation(fields: [evento_id], references: [id])
  nadadores            Nadador[]
}

model Nadador {
  id              Int         @id @default(autoincrement())
  nombre          String
  apellido        String
  club            String
  tiempo_registro String?     // e.g., "01:23.45"
  serie_id        Int
  serie           Serie       @relation(fields: [serie_id], references: [id])
  favoritos       Favoritos[]
}

model Favoritos {
  id         Int     @id @default(autoincrement())
  usuario_id Int
  nadador_id Int
  usuario    Usuario @relation(fields: [usuario_id], references: [id])
  nadador    Nadador @relation(fields: [nadador_id], references: [id])

  @@unique([usuario_id, nadador_id])
}
